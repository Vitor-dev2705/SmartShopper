{
  "version": 2,
  "builds": [
    {
      "src": "api/main.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    { "source": "/v1/(.*)", "destination": "api/main.py" },
    { "source": "/debug-db", "destination": "api/main.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}